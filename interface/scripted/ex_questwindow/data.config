	"strings" : {
		"instructions" : {
			"title" : "Task Terminal",
			"description" : "To select a task, click on its name on the left window, and relevant information will be displayed here.\n\nTasks also come with a color to represent your progress with them: \n^red;red^reset; : unavailable\n^yellow;yellow^reset; : available\n^cyan;cyan^reset; : in progress\n^green;green^reset; : complete.\n\nThere may be different task branches, which you can access by pressing the big image at the top of the window on the left. More become available as you unlock them."
		},

		"questlines" : {
			"tutorial" : {
				"title" : "Tutorials",
				"description" : "Learn the basics of what to expect as a Vanta through this series of quests. Along with a classic tutorial sequence reminiscent of the Starbound pre-1.0 days, you'll be informed about some of the more essential tools and mechanics that are available to Vanta players.\n\nThe ultimate goal is gaining access to the ^orange;Vanta Skill Grid^reset;, along with upgrading the saber and handgun weapons acquired in the Vanta intro mission."
			},

			"sb_story" : {
				"title" : "Starbound Story Quests",
				"description" : "The Starbound main story questline, made available to Vanta players. There are intermissions that will become available to Vanta players in between the main quests to help gear up for post-story content, exclusive to Vanta players."
			},

			"sb_misc" : {
				"title" : "Miscellaneous Quests",
				"description" : "Quests that don't necessarrily fit into major arcs will be placed here."
			}
		},
